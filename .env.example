# =============================================================================
# ETL Stack Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio.minio.svc.cluster.local:9000
MINIO_BUCKET_RAW=warehouse-raw
MINIO_BUCKET_SILVER=warehouse-silver
MINIO_BUCKET_GOLD=warehouse-gold
MINIO_ICEBERG_WAREHOUSE=s3://warehouse/

# AWS-style credentials (used by Spark, dbt, etc.)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000

# ----------------------------------------------------------------------------
# Nessie Catalog
# ----------------------------------------------------------------------------
NESSIE_URI=http://nessie.nessie.svc.cluster.local:19120/api/v1
NESSIE_DEFAULT_BRANCH=main
NESSIE_AUTH_TYPE=NONE

# ----------------------------------------------------------------------------
# Spark
# ----------------------------------------------------------------------------
SPARK_MASTER=spark://spark-master.spark.svc.cluster.local:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_EXECUTOR_CORES=2

# ----------------------------------------------------------------------------
# Airflow
# ----------------------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@airflow-postgres.airflow.svc.cluster.local:5432/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-change-in-production
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW_ADMIN_EMAIL=admin@example.com

# ----------------------------------------------------------------------------
# dbt
# ----------------------------------------------------------------------------
DBT_PROFILES_DIR=/opt/dbt
DBT_PROJECT_DIR=/opt/dbt
DBT_TARGET=dev

# ----------------------------------------------------------------------------
# Airbyte
# ----------------------------------------------------------------------------
AIRBYTE_VERSION=0.50.0
BASIC_AUTH_USERNAME=airbyte
BASIC_AUTH_PASSWORD=password

# ----------------------------------------------------------------------------
# Postgres (shared metadata store)
# ----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=metadata

# ----------------------------------------------------------------------------
# General
# ----------------------------------------------------------------------------
TZ=UTC
LOG_LEVEL=INFO
